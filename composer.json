{
  "name": "mage-os/project-community-edition",
  "description": "Mage-OS project tailored with mageos-maker",
  "require": {
    "mage-os/composer-dependency-version-audit-plugin": "3.1.0",
    "mage-os/composer-root-update-plugin": "3.1.0",
    "mage-os/product-community-edition": "3.1.0"
  },
  "require-dev": {
    "allure-framework/allure-phpunit": "^3.2",
    "brianium/paratest": "^7.14",
    "dealerdirect/phpcodesniffer-composer-installer": "^0.7 || ^1.0",
    "dg/bypass-finals": "^1.4",
    "friendsofphp/php-cs-fixer": "^3.22",
    "mage-os/magento-coding-standard": "3.1.0",
    "mage-os/magento2-functional-testing-framework": "3.1.0",
    "pdepend/pdepend": "^3@dev",
    "phpmd/phpmd": "^3@dev",
    "phpstan/phpstan": "^1.9",
    "phpunit/phpunit": "^12.0",
    "symfony/finder": "^7.4"
  },
  "type": "project",
  "extra": {
    "magento-force": "override",
    "bougie": {
      "recipe": "magento",
      "services": {
        "mariadb": "*",
        "redis": "*",
        "opensearch": "*",
        "rabbitmq": "*"
      }
    },
    "patches": {
      "mage-os/framework": {
        "Keep unix-socket db-host reconnectable (first _connect consumes host into unix_socket)": "patches/framework-pdo-mysql-socket-reconnect.patch"
      },
      "mage-os/magento2-base": {
        "Integration test framework: mariadb CLI tools accept a Unix-socket db-host": "patches/testframework-db-mysql-unix-socket.patch",
        "Integration test framework: parallel workers skip the racy test-module redeploy": "patches/testframework-parallel-deploy-test-modules.patch"
      }
    }
  },
  "autoload": {
    "psr-4": {
      "Magento\\Framework\\": "lib/internal/Magento/Framework/",
      "Magento\\Setup\\": "setup/src/Magento/Setup/",
      "Magento\\": "app/code/Magento/",
      "MageOS\\Installer\\": "setup/src/MageOS/Installer/"
    },
    "psr-0": {
      "": [
        "app/code/",
        "generated/code/"
      ]
    },
    "files": [
      "app/etc/NonComposerComponentRegistration.php"
    ],
    "exclude-from-classmap": [
      "**/dev/**",
      "**/update/**",
      "**/Test/Fixture/**",
      "**/Test/Integration/**",
      "**/Test/Mftf/**",
      "**/Test/Unit/**"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Magento\\Sniffs\\": "dev/tests/static/framework/Magento/Sniffs/",
      "Magento\\Tools\\": "dev/tools/Magento/Tools/",
      "Magento\\Tools\\Sanity\\": "dev/build/publication/sanity/Magento/Tools/Sanity/",
      "Magento\\TestFramework\\Inspection\\": "dev/tests/static/framework/Magento/TestFramework/Inspection/",
      "Magento\\TestFramework\\Utility\\": "dev/tests/static/framework/Magento/TestFramework/Utility/",
      "Magento\\PhpStan\\": "dev/tests/static/framework/Magento/PhpStan/",
      "MageOS\\Installer\\Test\\": "setup/tests/"
    }
  },
  "license": [
    "OSL-3.0",
    "AFL-3.0"
  ],
  "repositories": [
    {
      "type": "composer",
      "url": "https://repo.mage-os.org/"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "php-http/discovery": true,
      "mage-os/composer-dependency-version-audit-plugin": true,
      "mage-os/composer-root-update-plugin": true,
      "mage-os/inventory-composer-installer": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "mage-os/magento-composer-installer": true
    }
  }
}

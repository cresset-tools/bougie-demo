.diff{display:flex;gap:14px;flex-wrap:wrap}
.diffcol{flex:1 1 320px;min-width:0;background:#fff;border:1px solid #e2e5ea;border-radius:8px;padding:10px 14px}
.diffcol h3{margin:0 0 8px;font-size:13px}
.diffcol h3.gained{color:#2e7d32}.diffcol h3.lost{color:#c62828}
.diffcol ul{margin:0;padding:0;list-style:none}
.diffcol li{font:12px ui-monospace,monospace;word-break:break-all;padding:3px 0;border-top:1px solid #f0f2f5}
.diffcol li:first-child{border-top:0}
.diffcol a{color:#25508f;text-decoration:none}
.diffcol .none{color:#8a93a3;font-size:12.5px;margin:0}
.was{font:10.5px system-ui,sans-serif;color:#fff;background:#9aa4b1;border-radius:8px;padding:0 6px;margin-left:4px;white-space:nowrap}
.was.s-fail,.was.s-error{background:#e53935}.was.s-skip{background:#b0bec5}
.skipdelta{font-size:12px;color:#8a93a3;margin:8px 0 0}
.rerun{font-size:11px;color:#8a93a3;font-variant-numeric:tabular-nums}
.hint{font-size:12.5px;color:#5c6675;margin:0 0 12px}
tr.sub td{background:#fafbfc;color:#8a93a3;font-size:12px}
tr.sub a{color:#7a90b5;text-decoration:none}
tr.sub a:hover{text-decoration:underline}
tr.sub .dim code{color:#7a90b5}
.flakeh{color:#ef6c00}
.flakeh small{color:#8a93a3;font-weight:400;font-size:12.5px}
ul.flakelist{margin:0;padding:0;list-style:none}
ul.flakelist li{font:12px ui-monospace,monospace;padding:3px 0;border-top:1px solid #f0f2f5;word-break:break-all}
ul.flakelist li:first-child{border-top:0}
ul.flakelist a{color:#25508f;text-decoration:none}
CSS;

$pageOpen = function (string $title, string $crumb) use ($css): string {
    return "<!doctype html><meta charset=utf-8><meta name=viewport content=\"width=device-width,initial-scale=1\">"
        . '<title>' . h($title) . "</title><style>$css</style><main><div class=crumb>$crumb</div>";
};

// ---- classify ------------------------------------------------------------------
$failing = array_filter($tests, fn ($t) => $t['s'] === 'fail' || $t['s'] === 'error');
uksort($failing, function ($a, $b) use ($diagnosis) {
    $rank = fn ($id) => match ($diagnosis[$id]['diagnosis'] ?? 'undiagnosed') {
        'deterministic' => 0, 'flaky' => 1, 'context-dependent' => 2, default => 3,
    };
    return [$rank($a), $a] <=> [$rank($b), $b];
});
$newFailures = [];
foreach ($failing as $id => $t) {
    if (($prev['tests'][$id]['s'] ?? null) === 'pass') {
        $newFailures[$id] = true;
    }
}

// ---- diff vs the previous run ---------------------------------------------------
// Which tests moved onto / off the success (pass) list since $prev. Fixed =
// was failing, now green; regressed = was green, now failing. Skip transitions
// are counted separately so a mass ACL-scaffold skip doesn't drown the signal.
$fixed = $regressed = [];
$nowSkipped = $unskipped = 0;
if ($prev) {
    foreach ($tests as $id => $t) {
        $pv  = $prev['tests'][$id]['s'] ?? null;
        $cur = $t['s'];
        if ($pv === null) {
            continue; // brand-new test, not a transition
        }
        if ($cur === 'pass' && in_array($pv, ['fail', 'error'], true)) {
            $fixed[$id] = $prev['tests'][$id];
        } elseif ($cur !== 'pass' && $cur !== 'skip' && $pv === 'pass') {
            $regressed[$id] = $t;
        } elseif ($cur === 'skip' && $pv === 'pass') {
            $nowSkipped++;
        } elseif ($cur === 'pass' && $pv === 'skip') {
            $unskipped++;
        }
    }
}
// Flakes: tests that flipped pass<->fail between two runs of the *same*
// commit (identical code, different outcome). Only meaningful once a commit
// has been re-run; 0 on a commit's first run.
$flakes = [];
if ($sameCommitPrev) {
    foreach ($tests as $id => $t) {
        $pv  = $sameCommitPrev['tests'][$id]['s'] ?? null;
        $cur = $t['s'];
        if ($pv === null || $pv === 'skip' || $cur === 'skip') {
            continue;
        }
        if (($pv === 'pass') !== ($cur === 'pass')) {
            $flakes[$id] = ['from' => $pv, 'to' => $cur];
        }
    }
}
$totTests = count($tests);
$totFail  = count($failing);
$totSkip  = count(array_filter($tests, fn ($t) => $t['s'] === 'skip'));
$totTime  = array_sum(array_column($jobs, 'time'));

// ---- job pages -------------------------------------------------------------------
foreach ($jobs as $slug => $j) {
    $name = str_replace('--', '/', $slug);
    $crumb = '<a href="../../index.html">runs</a> › <a href="../index.html">'
        . h(substr($sha, 0, 12)) . '</a> › ' . h($name);
    $p = $pageOpen("$name @ " . substr($sha, 0, 10), $crumb);
    $bad = $j['failures'] + $j['errors'];
    $p .= '<h1>' . h($name) . ' <small>' . $j['tests'] . ' tests · '
        . ($bad ? "<b style=\"color:#c62828\">$bad failing</b>" : '<b style="color:#2e7d32">green</b>')
        . ' · ' . $j['skipped'] . ' skipped · ' . gmdate('i:s', (int) $j['time']) . '</small></h1>';

    // failing first, then the rest in run order
    $ids = $j['ids'];
    usort($ids, function ($a, $b) use ($tests) {
        $bad = fn ($id) => in_array($tests[$id]['s'], ['fail', 'error'], true) ? 0 : 1;
        return [$bad($a), $a] <=> [$bad($b), $b];
    });
    $p .= '<table><tr><th>test</th><th class=num>seconds</th><th>history</th></tr>';
    foreach ($ids as $id) {
        $t = $tests[$id];
        $isBad = in_array($t['s'], ['fail', 'error'], true);
        $p .= '<tr' . ($isBad ? ' class=rf' : '') . ' id="' . anchor($id) . '"><td>'
            . '<span class="st st-' . $t['s'] . '"></span><span class=tid>' . h($id) . '</span>';
        if ($isBad) {
            $p .= '<details><summary>details</summary>'
                . failureDetail($id, $t, $diagnosis, $newFailures, $history) . '</details>';
        } elseif ($t['s'] === 'skip' && isset($skipReasons[$id])) {
            $p .= '<div class=skipwhy>' . h($skipReasons[$id]) . '</div>';
        }
        $p .= '</td><td class=num>' . number_format($t['t'], 2) . '</td><td>'
            . spark($history, $id) . '</td></tr>';
    }
    $p .= '</table></main>';
    file_put_contents("$out/$sha/jobs/$slug.html", $p);
}

// ---- run overview -------------------------------------------------------------------
$p = $pageOpen('mageos-magento2 @ ' . substr($sha, 0, 10), '<a href="../index.html">runs</a> › ' . h(substr($sha, 0, 12)));
$p .= '<h1>mageos-magento2 <code>' . h(substr($sha, 0, 12)) . '</code></h1>';
$p .= '<p>' . h(date('Y-m-d H:i T'))
    . ($sameCommitPrev ? ' · latest of several runs of this commit (<a href="../index.html">see all</a>)' : '')
    . ' · <a href="https://github.com/mage-os/mageos-magento2/commit/'
    . h($sha) . '">commit on GitHub</a></p>';
$p .= '<div class=tot>'
    . '<div><b>' . number_format($totTests) . '</b>tests</div>'
    . '<div><b style="color:' . ($totFail ? '#c62828' : '#2e7d32') . '">' . $totFail . '</b>failing</div>'
    . '<div><b style="color:' . (count($regressed) ? '#c62828' : 'inherit') . '">' . count($regressed) . '</b>newly failing</div>'
    . '<div><b style="color:' . (count($fixed) ? '#2e7d32' : 'inherit') . '">' . count($fixed) . '</b>newly passing</div>'
    . '<div><b>' . $totSkip . '</b>skipped</div>'
    . '<div><b>' . gmdate('H:i:s', (int) $totTime) . '</b>test time (sum)</div></div>';

// ---- changes since previous run ----
if ($prev && ($fixed || $regressed || $nowSkipped || $unskipped)) {
    $linkRow = function (string $id) use ($tests): string {
        $job = $tests[$id]['job'] ?? '';
        return $job
            ? '<a href="jobs/' . h($job) . '.html#' . anchor($id) . '">' . h($id) . '</a>'
            : h($id);
    };
    $p .= '<h2>Changes vs previous commit <code>' . h(substr($prev['sha'], 0, 12)) . '</code> '
        . '<small>(' . h(date('Y-m-d', strtotime($prev['date']))) . ')</small></h2>';
    $p .= '<div class=diff>';
    $p .= '<div class=diffcol><h3 class=gained>&#10003; Now passing (' . count($fixed) . ')</h3>';
    if ($fixed) {
        $p .= '<ul>';
        foreach ($fixed as $id => $pt) {
            $p .= '<li>' . $linkRow($id) . ' <span class="was s-' . h($pt['s']) . '">was ' . h($pt['s']) . '</span></li>';
        }
        $p .= '</ul>';
    } else {
        $p .= '<p class=none>none</p>';
    }
    $p .= '</div>';
    $p .= '<div class=diffcol><h3 class=lost>&#10007; Newly failing (' . count($regressed) . ')</h3>';
    if ($regressed) {
        $p .= '<ul>';
        foreach ($regressed as $id => $t) {
            $p .= '<li>' . $linkRow($id) . ' <span class="was s-' . h($t['s']) . '">' . h($t['s']) . '</span></li>';
        }
        $p .= '</ul>';
    } else {
        $p .= '<p class=none>none</p>';
    }
    $p .= '</div></div>';
    if ($nowSkipped || $unskipped) {
        $bits = [];
        if ($nowSkipped) { $bits[] = "$nowSkipped newly skipped"; }
        if ($unskipped)  { $bits[] = "$unskipped no longer skipped"; }
        $p .= '<p class=skipdelta>' . h(implode(' · ', $bits)) . '</p>';
    }
}

// ---- flaky tests (flips vs the previous run of the *same* commit) ----
if ($flakes) {
    $linkRow = function (string $id) use ($tests): string {
        $job = $tests[$id]['job'] ?? '';
        return $job
            ? '<a href="jobs/' . h($job) . '.html#' . anchor($id) . '">' . h($id) . '</a>'
            : h($id);
    };
    $p .= '<h2 class=flakeh>&#9888; Flaky tests (' . count($flakes) . ') '
        . '<small>same commit re-run &mdash; identical code, flipped result</small></h2>';
    $p .= '<ul class=flakelist>';
    foreach ($flakes as $id => $fl) {
        $p .= '<li>' . $linkRow($id)
            . ' <span class="was s-' . h($fl['from']) . '">' . h($fl['from'])
            . '</span> &rarr; <span class="was s-' . h($fl['to']) . '">' . h($fl['to']) . '</span></li>';
    }
    $p .= '</ul>';
}

$p .= '<h2>Jobs</h2><div class=grid>';
foreach ($jobs as $slug => $j) {
    $bad = $j['failures'] + $j['errors'];
    $cls = $bad ? 'bad' : ($j['tests'] === 0 ? 'warn' : '');
    $p .= "<a class=\"$cls\" href=\"jobs/" . h($slug) . '.html"><span>' . h(str_replace('--', '/', $slug))
        . '</span><span>' . ($bad ? "$bad ✗" : '✓') . '</span></a>';
}
$p .= '</div>';

$p .= '<h2>Failing tests (' . $totFail . ')</h2>';
if (!$failing) {
    $p .= '<p><b style="color:#2e7d32">Suite is green.</b></p>';
}
foreach ($failing as $id => $t) {
    $p .= '<div class=fail><h3><a href="jobs/' . h($t['job']) . '.html#' . anchor($id) . '">' . h($id) . '</a></h3>'
        . failureDetail($id, $t, $diagnosis, $newFailures, $history) . '</div>';
}

// skipped, grouped by reason
$skipGroups = [];
foreach ($tests as $id => $t) {
    if ($t['s'] === 'skip') {
        $reason = $skipReasons[$id] ?? '(no reason recorded)';
        $skipGroups[$reason]['n'] = ($skipGroups[$reason]['n'] ?? 0) + 1;
        $skipGroups[$reason]['example'] ??= $id;
    }
}
uasort($skipGroups, fn ($a, $b) => $b['n'] <=> $a['n']);
$p .= '<h2>Skipped tests (' . $totSkip . '), by reason</h2>'
    . '<table><tr><th class=num>count</th><th>reason</th><th>example</th></tr>';
foreach (array_slice($skipGroups, 0, 40, true) as $reason => $g) {
    $ex = $g['example'];
    $p .= '<tr><td class=num>' . $g['n'] . '</td><td>' . h(mb_substr($reason, 0, 160)) . '</td>'
        . '<td><a href="jobs/' . h($tests[$ex]['job']) . '.html#' . anchor($ex)
        . '"><span class=tid>' . h(mb_substr($ex, 0, 80)) . '</span></a></td></tr>';
}
if (count($skipGroups) > 40) {
    $p .= '<tr><td class=num>…</td><td>' . (count($skipGroups) - 40) . ' more distinct reasons</td><td></td></tr>';
}
$p .= '</table>';

$slowest = $tests;
uasort($slowest, fn ($a, $b) => $b['t'] <=> $a['t']);
$p .= '<h2>Slowest tests</h2><table><tr><th class=num>seconds</th><th>test</th></tr>';
foreach (array_slice($slowest, 0, 20, true) as $id => $t) {
    $p .= '<tr><td class=num>' . number_format($t['t'], 1) . '</td><td><a href="jobs/' . h($t['job'])
        . '.html#' . anchor($id) . '"><span class=tid>' . h($id) . '</span></a></td></tr>';
}
$p .= '</table></main>';
file_put_contents("$out/$sha/index.html", $p);

// ---- runs index -----------------------------------------------------------------------
// Rebuilt from the baseline files (the source of truth) each run, so it lists
// EVERY run — including re-runs of the same commit — with correct, stable
// stats: newly failing/passing = vs the previous *different* commit (what the
// code changed), flaky = flips vs the previous run of the *same* commit.
// Memory-safe: only the current, immediately-prior, and previous-distinct-
// commit baselines are held at once.
$runsFile  = "$out/runs.json";
$histFiles = glob("$baseDir/baselines/*.json");
usort($histFiles, fn ($a, $b) => strcmp($runTime($a), $runTime($b)));
$runRows  = [];
$lastRun  = null;   // immediately previous run
$prevDiff = null;   // last run of the previous distinct commit
foreach ($histFiles as $f) {
    $run = json_decode((string) file_get_contents($f), true);
    if (!$run || !isset($run['tests'])) {
        continue;
    }
    if ($lastRun && $lastRun['sha'] !== ($run['sha'] ?? null)) {
        $prevDiff = $lastRun;
    }
    $prevSame = ($lastRun && $lastRun['sha'] === ($run['sha'] ?? null)) ? $lastRun : null;
    $failing = $newF = $fixedF = $flakyF = 0;
    foreach ($run['tests'] as $id => $t) {
        $cur = $t['s'];
        if ($cur === 'fail' || $cur === 'error') {
            $failing++;
        }
        if ($prevDiff) {
            $pv = $prevDiff['tests'][$id]['s'] ?? null;
            if ($pv === 'pass' && ($cur === 'fail' || $cur === 'error')) {
                $newF++;
            } elseif (($pv === 'fail' || $pv === 'error') && $cur === 'pass') {
                $fixedF++;
            }
        }
        if ($prevSame) {
            $pv = $prevSame['tests'][$id]['s'] ?? null;
            if ($pv !== null && $pv !== 'skip' && $cur !== 'skip' && (($pv === 'pass') !== ($cur === 'pass'))) {
                $flakyF++;
            }
        }
    }
    $runRows[] = [
        'sha' => $run['sha'] ?? '', 'date' => $run['date'] ?? '',
        'tests' => count($run['tests']), 'failing' => $failing,
        'new' => $newF, 'fixed' => $fixedF, 'flaky' => $flakyF,
    ];
    $lastRun = ['sha' => $run['sha'] ?? '', 'date' => $run['date'] ?? '', 'tests' => $run['tests']];
    unset($run);
}
file_put_contents($runsFile, json_encode($runRows, JSON_PRETTY_PRINT) . "\n");

$idx = $pageOpen('mageos-magento2 integration tests', 'mage-os/mageos-magento2 · main');
$idx .= '<h1>mageos-magento2 · integration test runs</h1>'
    . '<p class=hint><b>newly failing / passing</b> = what changed vs the previous <em>commit</em> '
    . '(stable across re-runs). <b>flaky</b> = tests that flipped pass&harr;fail between re-runs of '
    . 'the <em>same</em> commit &mdash; identical code, so definitive flakes. Re-runs are grouped '
    . 'under their commit.</p>'
    . '<div style="overflow-x:auto"><table><tr><th>date</th><th>commit</th><th class=num>tests</th>'
    . '<th class=num>failing</th><th class=num>newly failing</th><th class=num>newly passing</th>'
    . '<th class=num>flaky</th></tr>';
$numCell = fn ($v, string $col) => '<td class=num' . ($v ? " style=\"color:$col;font-weight:600\"" : '')
    . '>' . ($v ?: '·') . '</td>';
$prevSha = null;
foreach (array_reverse($runRows) as $r) {
    $isRerun = ($r['sha'] === $prevSha);
    $prevSha = $r['sha'];
    $color   = $r['failing'] ? '#c62828' : '#2e7d32';
    $flCell  = $numCell((int) ($r['flaky'] ?? 0), '#ef6c00');
    if ($isRerun) {
        $idx .= '<tr class=sub><td>&#8627; <a href="' . h($r['sha']) . '/index.html" class=rerun>'
            . h(substr($r['date'], 0, 16)) . '</a></td>'
            . '<td class=dim><a href="' . h($r['sha']) . '/index.html"><code>' . h(substr($r['sha'], 0, 12)) . '</code></a></td>'
            . '<td class=num>' . number_format($r['tests']) . '</td>'
            . '<td class=num style="color:' . $color . '">' . $r['failing'] . '</td>'
            . '<td class=num>·</td><td class=num>·</td>' . $flCell . '</tr>';
    } else {
        $idx .= '<tr><td>' . h(substr($r['date'], 0, 16)) . '</td>'
            . '<td><a href="' . h($r['sha']) . '/index.html"><code>' . h(substr($r['sha'], 0, 12)) . '</code></a></td>'
            . '<td class=num>' . number_format($r['tests']) . '</td>'
            . '<td class=num style="color:' . $color . ';font-weight:600">' . $r['failing'] . '</td>'
            . $numCell((int) ($r['new'] ?? 0), '#c62828') . $numCell((int) ($r['fixed'] ?? 0), '#2e7d32') . $flCell . '</tr>';
    }
}
$idx .= '</table></div></main>';
file_put_contents("$out/index.html", $idx);

printf(
    "report: %s/%s/index.html  (%d tests, %d failing, %d new, %d fixed, %d flaky, %d runs listed, %d job pages)\n",
    $out, $sha, $totTests, $totFail, count($newFailures), count($fixed), count($flakes), count($runRows), count($jobs)
);
